<mvc:View
    controllerName="com.parametricas.parametricasapp.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%">

    <f:DynamicPage id="pagePrincipal" headerExpanded="true">
        <f:title>
            <f:DynamicPageTitle id="dptMain">
                <f:heading>
                    <Title id="titleContrato" text="Dados do Contrato" level="H2" />
                </f:heading>
                <f:actions>
                    <SearchField 
                        id="sfBuscaContrato" 
                        width="300px" 
                        placeholder="Buscar Contrato" 
                        search=".onSearch" />
                    <Button id="btnCadastroParametrica" text="Cadastro de Paramétricas" type="Emphasized" press=".onCadastroParametricaPress" />
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader id="dphMain" pinnable="true">
                <layout:HorizontalLayout id="hlFilters" visible="{/headerVisible}">
                    <layout:VerticalLayout class="sapUiMediumMarginEnd">
                        <Label text="Data-Base Paramétrica:" />
                        <DatePicker value="{/headerData/dataBaseParametrica}" displayFormat="MM/yyyy" width="256px" editable="false" />
                    </layout:VerticalLayout>

                    <layout:VerticalLayout class="sapUiMediumMarginEnd">
                        <Label text="Período:" />
                        <ComboBox selectedKey="{/headerData/periodo}" width="256px" editable="true">
                            <core:Item key="mensal" text="Mensal" />
                            <core:Item key="anual" text="Anual" />
                        </ComboBox>
                    </layout:VerticalLayout>

                    <layout:VerticalLayout>
                        <Label text="Data-Base Reajuste:" />
                        <DatePicker value="{/headerData/dataBaseReajuste}" displayFormat="dd/MM/yyyy" width="256px" editable="true" />
                    </layout:VerticalLayout>
                </layout:HorizontalLayout>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <VBox id="vbMainContainer">
                <Toolbar visible="{/headerVisible}" style="Clear" height="1px" class="sapUiMediumMarginBottom" />

                <Table
                    id="tabelaContratos"
                    items="{/contratos}"
                    mode="MultiSelect"
                    visible="{/headerVisible}"
                    sticky="ColumnHeaders,HeaderToolbar">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="Itens do Contrato" level="H3" />
                            <ToolbarSpacer />
                            <Button id="btnEditar" text="Editar" icon="sap-icon://edit" press=".onEditarPress" />
                            <Button id="btnConcluir" text="Concluir" icon="sap-icon://accept" type="Accept" press=".onConcluidoPress" />
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column width="3rem"><Text text="ID" /></Column>
                        <Column><Text text="Nº Contrato" /></Column>
                        <Column><Text text="N.I Material" /></Column>
                        <Column><Text text="Material" /></Column>
                        <Column hAlign="Center"><Text text="Quantidade" /></Column>
                        <Column hAlign="Center"><Text text="Unidade" /></Column>
                        <Column hAlign="End"><Text text="Valor Unid" /></Column>
                        <Column hAlign="End"><Text text="Valor Total" /></Column>
                        <Column hAlign="End"><Text text="Valor Sugerido" /></Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{id}" />
                                <Text text="{ncontrato}" />
                                <Text text="{ni}" />
                                <Text text="{material}" />
                                <Text text="{quantidade}" />
                                <Text text="{unidade}" />
                                <Text text="{valorUnitario}" />
                                <Text text="{valorTotal}" />
                                <Text text="{valorSugerido}" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </f:content>
    </f:DynamicPage>
</mvc:View>