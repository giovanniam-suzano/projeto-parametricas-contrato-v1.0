<mvc:View
    controllerName="com.parametricas.parametricasapp.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%">

    <f:DynamicPage id="pagePrincipal" headerExpanded="true">

        <!-- ===================== -->
        <!-- TITLE -->
        <!-- ===================== -->
        <f:title>
            <f:DynamicPageTitle id="dptMain">
                <f:heading>
                    <Title id="titleContrato" text="Dados do Contrato" level="H2" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <!-- ===================== -->
        <!-- HEADER -->
        <!-- ===================== -->
        <f:header>
            <f:DynamicPageHeader id="dphMain" pinnable="true">
                <layout:HorizontalLayout id="hlFilters">

                    <layout:VerticalLayout id="vlDateFilter" class="sapUiMediumMarginEnd">
                        <Label id="lblDateBase" text="Data-Base:" />
                        <DatePicker
                            id="dpDateBase"
                            value="Jan 26, 2024"
                            displayFormat="MMM dd, yyyy"
                            width="256px" />
                    </layout:VerticalLayout>

                    <layout:VerticalLayout id="vlPeriodFilter">
                        <Label id="lblPeriod" text="Período:" />
                        <ComboBox id="cbPeriod" selectedKey="mensal" width="256px">
                            <core:Item id="itemMensal" key="mensal" text="Mensal" />
                            <core:Item id="itemAnual" key="anual" text="Anual" />
                            <core:Item id="itemBimestral" key="bimestral" text="Bimestral" />
                            <core:Item id="itemTrimestral" key="trimestral" text="Trimestral" />
                        </ComboBox>
                    </layout:VerticalLayout>

                </layout:HorizontalLayout>
            </f:DynamicPageHeader>
        </f:header>

        <!-- ===================== -->
        <!-- CONTENT -->
        <!-- ===================== -->
        <f:content>

            <Table
                id="tabelaContratos"
                mode="MultiSelect"
                sticky="ColumnHeaders,HeaderToolbar"
                items="{/contratos}">

                <!-- Toolbar -->
                <headerToolbar>
                    <OverflowToolbar id="otbActions">
                        <ToolbarSpacer id="tsSpacer" />
                        <SearchField
                            id="sfBusca"
                            width="280px"
                            placeholder="Search"
                            search=".onSearch" />
                        <ToolbarSeparator id="tsep1" />
                        <Button
                            id="btnEditar"
                            text="Editar"
                            icon="sap-icon://edit"
                            press=".onEditarPress" />
                        <ToolbarSeparator id="tsep2" />
                        <Button
                            id="btnConcluido"
                            text="Concluído"
                            icon="sap-icon://accept"
                            press=".onConcluidoPress" />
                    </OverflowToolbar>
                </headerToolbar>

                <!-- Columns -->
                <columns>
                    <Column id="colId">
                        <Text id="txtColId" text="ID" />
                    </Column>
                    <Column id="colMaterial">
                        <Text id="txtColMaterial" text="Material" />
                    </Column>
                    <Column id="colQtd" hAlign="Center">
                        <Text id="txtColQtd" text="Quantidade" />
                    </Column>
                    <Column id="colUnd" hAlign="Center">
                        <Text id="txtColUnd" text="Unidade" />
                    </Column>
                    <Column id="colVlUni" hAlign="End">
                        <Text id="txtColVlUni" text="Valor Unid" />
                    </Column>
                    <Column id="colVlTot" hAlign="End">
                        <Text id="txtColVlTot" text="Valor Total" />
                    </Column>
                    <Column id="colVlSug" hAlign="End">
                        <Text id="txtColVlSug" text="Valor Sugerido" />
                    </Column>
                </columns>

                <!-- Items (Template) -->
                <items>
                    <ColumnListItem id="cliContrato">
                        <cells>
                            <Text id="txtId" text="{id}" />
                            <Text id="txtMaterial" text="{material}" />
                            <Text id="txtQtd" text="{quantidade}" />
                            <Text id="txtUnd" text="{unidade}" />
                            <Text id="txtVlUni" text="{valorUnitario}" />
                            <Text id="txtVlTot" text="{valorTotal}" />
                            <Text id="txtVlSug" text="{valorSugerido}" />
                        </cells>
                    </ColumnListItem>
                </items>

            </Table>

        </f:content>

    </f:DynamicPage>

</mvc:View>