<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
    xmlns="sap.m">
    <Dialog id="dialogParametricas" contentWidth="950px" contentHeight="850px" verticalScrolling="true">
        <customHeader>
            <Bar>
                <contentLeft>
                    <HBox alignItems="Center" renderType="Bare">
                        <core:Icon src="sap-icon://request" class="sapUiTinyMarginEnd" />
                        <Title text="Cabeçalho" visible="{dialog>/isAllSelected}" />
                        <Title text="Item 1" visible="{= !${dialog>/isAllSelected} &amp;&amp; ${dialog>/selectedCount} === 1 }" />
                        <Title text="{= 'Item ' + (${dialog>/currentIndex} + 1) + ' de ' + ${dialog>/selectedCount} }" 
                               visible="{= !${dialog>/isAllSelected} &amp;&amp; ${dialog>/selectedCount} > 1 }" />
                    </HBox>
                </contentLeft>
            </Bar>
        </customHeader>
        <content>
            <VBox class="sapUiSmallMargin" visible="{dialog>/isAllSelected}">
                <form:SimpleForm layout="ResponsiveGridLayout" editable="true" 
                                 labelSpanXL="5" labelSpanL="5" labelSpanM="5" labelSpanS="12"
                                 emptySpanXL="3" emptySpanL="3" emptySpanM="3" emptySpanS="0"
                                 columnsXL="1" columnsL="1" columnsM="1" title="Dados do Cabeçalho">
                    <Label text="Nº do Contrato" />
                    <Text text="{dialog>/currentItem/ncontrato}" />
                    <Label text="Reajuste Total (%)" />
                    <Text text="{dialog>/currentItem/reajusteTotal}" />
                    
                    <Label text="Deseja alterar o reajuste total" visible="{dialog>/isNegociando}" />
                    <CheckBox selected="{dialog>/alterarReajusteTotal}" visible="{dialog>/isNegociando}" />
                </form:SimpleForm>

                <VBox visible="{= ${dialog>/isNegociando} &amp;&amp; ${dialog>/alterarReajusteTotal} }">
                    <form:SimpleForm layout="ResponsiveGridLayout" editable="true" 
                                     labelSpanXL="5" labelSpanL="5" labelSpanM="5" labelSpanS="12"
                                     emptySpanXL="3" emptySpanL="3" emptySpanM="3" emptySpanS="0"
                                     columnsXL="1" columnsL="1" columnsM="1">
                        <core:Title text="Negociação de Reajuste Total" />
                        <Label text="Reajuste Total (%):" />
                        <Input value="{dialog>/novoReajusteTotalGeral}" type="Number" width="256px" placeholder="Insira o valor que deseja altera" />
                    </form:SimpleForm>
                </VBox>

                <VBox items="{path: 'dialog>/globalIndices'}">
                    <form:SimpleForm layout="ResponsiveGridLayout" editable="true" 
                                     labelSpanXL="5" labelSpanL="5" labelSpanM="5" labelSpanS="12"
                                     emptySpanXL="3" emptySpanL="3" emptySpanM="3" emptySpanS="0"
                                     columnsXL="1" columnsL="1" columnsM="1">
                        <core:Title text="{= ${dialog>ordem} + 'º Índice (Geral)'}" />
                        
                        <Label text="Índice" />
                        <Input value="{dialog>tipoIndice}" editable="false" width="256px" />
                        
                        <Label text="Peso (%)" />
                        <Input value="{dialog>peso}" editable="false" width="256px" />

                        <Label text="Reajuste Projetado (%)" />
                        <Input value="{dialog>reajusteProjetado}" type="Number" editable="false" width="256px" />

                        <Label text="Negociação de Reajuste da Paramétrica" visible="{dialog>/isNegociando}" />
                        <Input value="{dialog>negociacaoReajuste}" type="Number" width="256px" visible="{dialog>/isNegociando}" placeholder="Insira o valor que deseja altera" />

                        <Label text="Deseja adicionar mais um índice" />
                        <ComboBox selectedKey="{dialog>addMore}" selectionChange=".onAdicionarIndiceGlobal" 
                                  width="256px" editable="{dialog>/isNegociando}">
                            <core:Item key="SIM" text="Sim" /><core:Item key="NAO" text="Não" />
                        </ComboBox>
                    </form:SimpleForm>
                </VBox>
            </VBox>

            <VBox items="{path: 'dialog>/selectedItems'}" visible="{= !${dialog>/isAllSelected} }">
                <VBox class="sapUiSmallMargin" visible="{= ${dialog>seq} === (${dialog>/currentIndex} + 1) }">
                    <form:SimpleForm layout="ResponsiveGridLayout" editable="true" 
                                     labelSpanXL="5" labelSpanL="5" labelSpanM="5" labelSpanS="12"
                                     emptySpanXL="3" emptySpanL="3" emptySpanM="3" emptySpanS="0"
                                     columnsXL="1" columnsL="1" columnsM="1" title="Dados do Item Selecionado">
                        <Label text="ID" /><Text text="{dialog>id}" />
                        <Label text="Nº Contrato" /><Text text="{dialog>ncontrato}" />
                        <Label text="N.I do material" /><Text text="{dialog>ni}" />
                        <Label text="Material" /><Text text="{dialog>material}" />
                        <Label text="Unidade" /><Text text="{dialog>unidade}" />
                        <Label text="Valor Atual" /><Text text="{dialog>valorUnitario}" />
                        <Label text="Valor Alterado" /><Text text="{dialog>valorAlterado}" />
                        <Label text="Reajuste Total (%)" /><Text text="{dialog>reajusteTotal}" />
                        
                        <Label text="Deseja alterar o reajuste total" visible="{dialog>/isNegociando}" />
                        <CheckBox selected="{dialog>/alterarReajusteTotal}" visible="{dialog>/isNegociando}" />
                    </form:SimpleForm>
                    
                    <VBox visible="{= ${dialog>/isNegociando} &amp;&amp; ${dialog>/alterarReajusteTotal} }">
                        <form:SimpleForm layout="ResponsiveGridLayout" editable="true" 
                                         labelSpanXL="5" labelSpanL="5" labelSpanM="5" labelSpanS="12"
                                         emptySpanXL="3" emptySpanL="3" emptySpanM="3" emptySpanS="0"
                                         columnsXL="1" columnsL="1" columnsM="1">
                            <core:Title text="Negociação de Reajuste Total" />
                            <Label text="Reajuste Total (%):" />
                            <Input value="{dialog>novoReajusteTotalItem}" type="Number" width="256px" placeholder="Insira o valor que deseja altera" />
                        </form:SimpleForm>
                    </VBox>
                    
                    <VBox items="{path: 'dialog>indices'}">
                        <form:SimpleForm layout="ResponsiveGridLayout" editable="true" 
                                         labelSpanXL="5" labelSpanL="5" labelSpanM="5" labelSpanS="12"
                                         emptySpanXL="3" emptySpanL="3" emptySpanM="3" emptySpanS="0"
                                         columnsXL="1" columnsL="1" columnsM="1">
                            <core:Title text="{= ${dialog>ordem} + 'º Índice'}" />
                            
                            <Label text="Índice" />
                            <Input value="{dialog>tipoIndice}" editable="false" width="256px" />
                            
                            <Label text="Peso (%)" />
                            <Input value="{dialog>peso}" editable="false" width="256px"/>

                            <Label text="Reajuste Projetado (%)" />
                            <Input value="{dialog>reajusteProjetado}" type="Number" editable="false" width="256px" />

                            <Label text="Negociação de Reajuste da Paramétrica" visible="{dialog>/isNegociando}" />
                            <Input value="{dialog>negociacaoReajuste}" type="Number" width="256px" visible="{dialog>/isNegociando}" placeholder="Insira o valor que deseja altera" />

                            <Label text="Deseja adicionar mais um índice" />
                            <ComboBox selectedKey="{dialog>addMore}" selectionChange=".onAdicionarIndice" 
                                      width="256px" editable="{dialog>/isNegociando}">
                                <core:Item key="SIM" text="Sim" /><core:Item key="NAO" text="Não" />
                            </ComboBox>
                        </form:SimpleForm>
                    </VBox>
                </VBox>
            </VBox>
        </content>
        <buttons>
            <Button text="Voltar" press=".onDialogVoltar" visible="{= !${dialog>/isAllSelected} &amp;&amp; ${dialog>/currentIndex} > 0 &amp;&amp; !${dialog>/isNegociando} }" />
            <Button text="Próximo Passo" type="Emphasized" press=".onDialogProximo" visible="{= !${dialog>/isAllSelected} &amp;&amp; (${dialog>/currentIndex} + 1) &lt; ${dialog>/selectedCount} &amp;&amp; !${dialog>/isNegociando} }" />
            <Button text="Aplicar Reajuste" type="Accept" press=".onAplicarReajuste" visible="{= !${dialog>/isNegociando} &amp;&amp; (${dialog>/isAllSelected} || (${dialog>/currentIndex} + 1) === ${dialog>/selectedCount}) }" />
            <Button text="Negociar" type="Reject" press=".onNegociar" visible="{= !${dialog>/isNegociando} }" />
            <Button text="Salvar" type="Accept" press=".onSalvarNegociacao" visible="{dialog>/isNegociando}" />
            <Button text="Cancelar" press=".onCancelarNegociacao" visible="{dialog>/isNegociando}" />
            <Button text="Sair" press=".onDialogCancel" />
        </buttons>
    </Dialog>
</core:FragmentDefinition>