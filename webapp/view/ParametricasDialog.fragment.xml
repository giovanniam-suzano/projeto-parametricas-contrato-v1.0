<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form">

    <Dialog
        id="dialogParametricas"
        title="Alteração de Paramétricas"
        contentWidth="900px"
        contentHeight="600px"
        verticalScrolling="true">

        <content>

            <Wizard
                id="wizardParametricas"
                finishButtonText="Concluir">

                <!-- ================= STEP 1 ================= -->
                <WizardStep
                    id="step1"
                    title="Paramétricas do Item {id}"
                    validated="true">

                    <!-- ===== RESUMO DO ITEM ===== -->
                    <VBox id="boxResumoItem" class="sapUiSmallMarginBottom">

                        <HBox id="hbResumoId">
                            <Text id="lblId" text="ID:" width="160px"/>
                            <Text id="txtIdResumo" text="{id}"/>
                        </HBox>

                        <HBox id="hbResumoMaterial">
                            <Text id="lblMaterial" text="Material:" width="160px"/>
                            <Text id="txtMaterialResumo" text="{material}"/>
                        </HBox>

                        <HBox id="hbResumoQtd">
                            <Text id="lblQtd" text="Quantidade:" width="160px"/>
                            <Text id="txtQtdResumo" text="{quantidade}"/>
                        </HBox>

                        <HBox id="hbResumoValor">
                            <Text id="lblValor" text="Valor Total:" width="160px"/>
                            <Text id="txtValorResumo" text="{valorTotal}"/>
                        </HBox>

                    </VBox>

                    <!-- ===== LISTA DINÂMICA DE ÍNDICES ===== -->
                    <VBox
                        id="boxListaIndices"
                        items="{dialog>/indices}">

                        <!-- ===== TEMPLATE ===== -->
                        <VBox
                            id="boxIndiceItem"
                            class="sapUiMediumMarginBottom">

                            <form:SimpleForm
                                id="formIndice"
                                layout="ColumnLayout"
                                columnsM="1"
                                columnsL="1"
                                columnsXL="1">

                                <core:Title
                                    id="titleDefIndices"
                                    text="Definição de Índices" />

                                <Label
                                    id="lblIndice"
                                    text="{= ${dialog>ordem} + 'º Índice da Paramétrica'}"
                                    required="true"/>

                                <ComboBox
                                    id="cbIndice"
                                    width="256px">
                                    <core:Item id="itemIPA" key="IPA" text="IPA"/>
                                    <core:Item id="itemIPCA" key="IPCA" text="IPCA"/>
                                    <core:Item id="itemIGPM" key="IGP-M" text="IGP-M"/>
                                    <core:Item id="itemINCC" key="INCC" text="INCC"/>
                                </ComboBox>

                                <Label
                                    id="lblPeso"
                                    text="{= ${dialog>ordem} + 'º Peso do Índice (%)'}"
                                    required="true"/>

                                <Input
                                    id="inpPeso"
                                    type="Number"
                                    placeholder="Ex: 15"/>

                                <Label
                                    id="lblPergunta"
                                    text="Deseja adicionar mais um índice de Paramétrica para esse item?"
                                    required="true"/>

                                <ComboBox
                                    id="cbPergunta"
                                    width="200px"
                                    selectionChange=".onAdicionarIndice">
                                    <core:Item id="itemSim" key="SIM" text="Sim"/>
                                    <core:Item id="itemNao" key="NAO" text="Não"/>
                                </ComboBox>

                            </form:SimpleForm>

                        </VBox>

                    </VBox>

                </WizardStep>

                <!-- STEPS FUTUROS -->
                <WizardStep id="step2" title="Item"/>
                <WizardStep id="step3" title="Item"/>
                <WizardStep id="step4" title="Item"/>
                <WizardStep id="step5" title="Item"/>
                <WizardStep id="step6" title="Item"/>

            </Wizard>

        </content>

        <buttons>
            <Button id="btnDialogVoltar" text="Voltar" press=".onDialogVoltar"/>
            <Button id="btnDialogProximo" text="Próximo Passo" type="Emphasized" press=".onDialogProximo"/>
            <Button id="btnDialogCancel" text="Cancelar" press=".onDialogCancel"/>
        </buttons>

    </Dialog>

</core:FragmentDefinition>