<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form">
    <Dialog id="dialogCadastroParametrica" contentWidth="950px" contentHeight="750px" verticalScrolling="true">
        <customHeader>
            <Bar>
                <contentLeft>
                    <HBox alignItems="Center" renderType="Bare">
                        <core:Icon src="sap-icon://add-coursebook" class="sapUiTinyMarginEnd" />
                        <!-- Títulos dos 3 Cenários -->
                        <Title text="Cadastrando Paramétricas de Cabeçalho" visible="{dialog>/isAllSelected}" />
                        <Title text="Inserindo Paramétricas do Item 1" visible="{= !${dialog>/isAllSelected} &amp;&amp; ${dialog>/selectedCount} === 1 }" />
                        <Title text="{= 'Inserindo Paramétricas do Item ' + (${dialog>/currentIndex} + 1) + ' de ' + ${dialog>/selectedCount} }" 
                               visible="{= !${dialog>/isAllSelected} &amp;&amp; ${dialog>/selectedCount} > 1 }" />
                    </HBox>
                </contentLeft>
            </Bar>
        </customHeader>
        <content>
            <!-- CENÁRIO 1: CABEÇALHO -->
            <VBox class="sapUiSmallMargin" visible="{dialog>/isAllSelected}">
                <VBox items="{dialog>/globalIndices}">
                    <!-- labelSpan="4" + emptySpan="4" deixa exatamente 4 colunas (33%) para o campo central -->
                    <form:SimpleForm layout="ResponsiveGridLayout" editable="true"
                                     labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                                     emptySpanXL="4" emptySpanL="4" emptySpanM="4" emptySpanS="0"
                                     columnsXL="1" columnsL="1" columnsM="1">
                        <core:Title text="{= ${dialog>ordem} + 'º Índice (Geral)'}" />
                        <Label text="Tipo de Índice" required="true" />
                        <ComboBox selectedKey="{dialog>tipoIndice}" width="100%">
                            <core:Item key="IPCA" text="IPCA" /><core:Item key="IGP-M" text="IGP-M" />
                        </ComboBox>
                        <Label text="Valor do índice selecionado" />
                        <Input value="{dialog>valorIndice}" type="Number" width="100%" />
                        <Label text="Peso (%)" required="true" />
                        <Input value="{dialog>peso}" change=".onPesoChange" width="100%" />
                        <Label text="Deseja adicionar mais um índice" />
                        <ComboBox selectedKey="{dialog>addMore}" selectionChange=".onAdicionarIndiceGlobal" width="100%">
                            <core:Item key="SIM" text="Sim" /><core:Item key="NAO" text="Não" />
                        </ComboBox>
                    </form:SimpleForm>
                </VBox>
            </VBox>

            <!-- CENÁRIOS 2 e 3: ITENS -->
            <VBox items="{dialog>/selectedItems}" visible="{= !${dialog>/isAllSelected} }">
                <VBox class="sapUiSmallMargin" visible="{= ${dialog>seq} === (${dialog>/currentIndex} + 1) }">
                    <form:SimpleForm layout="ResponsiveGridLayout" editable="false" labelSpanL="4" columnsL="2">
                        <core:Title text="Dados do Item Selecionado" />
                        <Label text="ID" /><Text text="{dialog>id}" />
                        <Label text="Contrato" /><Text text="{dialog>ncontrato}" />
                        <Label text="N.I" /><Text text="{dialog>ni}" />
                        <Label text="Material" /><Text text="{dialog>material}" />
                        <Label text="Qtd" /><Text text="{dialog>quantidade}" />
                        <Label text="Und" /><Text text="{dialog>unidade}" />
                        <Label text="Vl Unid" /><Text text="{dialog>valorUnitario}" />
                        <Label text="Vl Total" /><Text text="{dialog>valorTotal}" />
                    </form:SimpleForm>
                    <VBox items="{dialog>indices}">
                        <form:SimpleForm layout="ResponsiveGridLayout" editable="true"
                                         labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                                         emptySpanXL="4" emptySpanL="4" emptySpanM="4" emptySpanS="0">
                            <core:Title text="{= ${dialog>ordem} + 'º Índice'}" />
                            <Label text="Tipo" required="true" />
                            <ComboBox selectedKey="{dialog>tipoIndice}" width="100%">
                                <core:Item key="IPCA" text="IPCA" /><core:Item key="IGP-M" text="IGP-M" />
                            </ComboBox>
                            <Label text="Valor do índice selecionado" />
                            <Input value="{dialog>valorIndice}" type="Number" width="100%" />
                            <Label text="Peso (%)" required="true" />
                            <Input value="{dialog>peso}" change=".onPesoChange" width="100%"/>
                            <Label text="Deseja adicionar mais um índice" />
                            <ComboBox selectedKey="{dialog>addMore}" selectionChange=".onAdicionarIndice" width="100%">
                                <core:Item key="SIM" text="Sim" /><core:Item key="NAO" text="Não" />
                            </ComboBox>
                        </form:SimpleForm>
                    </VBox>
                </VBox>
            </VBox>
        </content>
        <buttons>
            <Button text="Voltar" press=".onDialogVoltar" 
                    visible="{= !${dialog>/isAllSelected} &amp;&amp; ${dialog>/currentIndex} > 0 }" />
            
            <Button text="Próximo Passo" type="Emphasized" press=".onDialogProximo" 
                    visible="{= !${dialog>/isAllSelected} &amp;&amp; (${dialog>/currentIndex} + 1) &lt; ${dialog>/selectedCount} }" />
            
            <Button text="Salvar" type="Accept" press=".onSalvar" 
                    visible="{= ${dialog>/isAllSelected} || (${dialog>/currentIndex} + 1) === ${dialog>/selectedCount} }" />
            
            <Button text="Cancelar" press=".onDialogCancel" />
        </buttons>
    </Dialog>
</core:FragmentDefinition>