<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:form="sap.ui.layout.form">
    <Dialog id="dialogCadastroParametrica" contentWidth="600px" contentHeight="600px" verticalScrolling="true">
        <customHeader>
            <Bar>
                <contentLeft>
                    <HBox alignItems="Center"><core:Icon src="sap-icon://add-document" class="sapUiTinyMarginEnd" /><Title text="Cadastro de Paramétricas" /></HBox>
                </contentLeft>
            </Bar>
        </customHeader>
        <content>
            <VBox items="{dialog>/indicesCadastro}">
                <form:SimpleForm layout="ColumnLayout" editable="true">
                    <core:Title text="{= ${dialog>ordem} + 'º Índice'}" />
                    <Label text="Valor" required="true" /><Input value="{dialog>valor}" change=".onPesoChange" />
                    <Label text="Tipo" required="true" /><ComboBox selectedKey="{dialog>tipoIndice}"><core:Item key="IPA" text="IPA" /><core:Item key="IPCA" text="IPCA" /></ComboBox>
                    <Label text="Peso (%)" required="true" /><Input value="{dialog>peso}" change=".onPesoChange" />
                    <Label text="Data-Base" required="true" /><DatePicker value="{dialog>dataBaseParametrica}" displayFormat="MM/yyyy" />
                    <Label text="Deseja adicionar mais um índice" /><ComboBox selectedKey="{dialog>addMore}" selectionChange=".onAdicionarIndiceCadastro"><core:Item key="SIM" text="Sim" /><core:Item key="NAO" text="Não" /></ComboBox>
                </form:SimpleForm>
            </VBox>
        </content>
        <buttons><Button text="Salvar" type="Accept" press=".onDialogCancel" /><Button text="Fechar" press=".onDialogCancel" /></buttons>
    </Dialog>
</core:FragmentDefinition>